#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-3.0-only

START=22
STOP=78
USE_PROCD=1

RUNTIME_DIR=/var/run/gl-modem-community
STOCK_LIST=/lib/modem_data/modem_list.json
MERGED_LIST=$RUNTIME_DIR/modem_list.json

is_mounted() {
	grep -F " $STOCK_LIST " /proc/mounts >/dev/null 2>&1
}

start_service() {
	local enabled
	config_load gl_modem_community
	config_get_bool enabled global enabled 1
	[ "$enabled" -eq 1 ] || return 0

	mkdir -p "$RUNTIME_DIR"
	/usr/libexec/gl-modem-community/merge-models \
		"$STOCK_LIST" /usr/share/gl-modem-community/drivers.d "$MERGED_LIST" || return 1

	is_mounted || mount -o bind "$MERGED_LIST" "$STOCK_LIST" || return 1
}

stop_service() {
	is_mounted && umount "$STOCK_LIST"
	return 0
}

reload_service() {
	stop_service
	start_service
	ubus call cellular.status cleanup_resources >/dev/null 2>&1 || true
}
