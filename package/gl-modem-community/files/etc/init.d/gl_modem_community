#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-3.0-only

START=22
STOP=78
USE_PROCD=1

RUNTIME_DIR=${RUNTIME_DIR:-/var/run/gl-modem-community}
STACK_FILE=${STACK_FILE:-$RUNTIME_DIR/stack}
RUNTIME_STACK=${RUNTIME_STACK:-/usr/libexec/gl-modem-community/runtime-stack}
LEGACY_BUS=${LEGACY_BUS:-/usr/libexec/gl-modem-community/legacy-bus}
STOCK_LIST=${STOCK_LIST:-/lib/modem_data/modem_list.json}
MERGED_LIST=${MERGED_LIST:-$RUNTIME_DIR/modem_list.json}
MODEM_AT=${MODEM_AT:-/usr/bin/modem_AT}
STOCK_MODEM_AT=${STOCK_MODEM_AT:-$RUNTIME_DIR/modem_AT.stock}
MODEM_AT_WRAPPER=${MODEM_AT_WRAPPER:-/usr/libexec/gl-modem-community/modem_AT-wrapper}
NETWORK_REPAIR=${NETWORK_REPAIR:-/usr/libexec/gl-modem-community/fm350-network-repair}
MERGE_MODELS=${MERGE_MODELS:-/usr/libexec/gl-modem-community/merge-models}
PROC_MOUNTS=${PROC_MOUNTS:-/proc/mounts}
CP_BIN=${CP_BIN:-cp}
MOUNT_BIN=${MOUNT_BIN:-mount}
UMOUNT_BIN=${UMOUNT_BIN:-umount}
LOGGER_BIN=${LOGGER_BIN:-logger}

is_model_list_mounted() {
	grep -F " $STOCK_LIST " "$PROC_MOUNTS" >/dev/null 2>&1
}

is_modem_at_mounted() {
	grep -F " $MODEM_AT " "$PROC_MOUNTS" >/dev/null 2>&1
}

mount_modem_at_wrapper() {
	is_modem_at_mounted && return 0
	"$CP_BIN" -p "$MODEM_AT" "$STOCK_MODEM_AT" || return 1
	"$MOUNT_BIN" -o bind "$MODEM_AT_WRAPPER" "$MODEM_AT" || return 1
}

start_repair_watcher() {
	"$NETWORK_REPAIR" || true
	procd_open_instance fm350-network-repair
	procd_set_param command "$NETWORK_REPAIR" --watch
	procd_set_param respawn 3600 5 5
	procd_close_instance
}

start_modern() {
	"$MERGE_MODELS" \
		"$STOCK_LIST" /usr/share/gl-modem-community/drivers.d "$MERGED_LIST" ||
		return 1
	mount_modem_at_wrapper || return 1
	if ! is_model_list_mounted &&
		! "$MOUNT_BIN" -o bind "$MERGED_LIST" "$STOCK_LIST"; then
		is_modem_at_mounted && "$UMOUNT_BIN" "$MODEM_AT"
		return 1
	fi
	start_repair_watcher
}

start_legacy() {
	"$LEGACY_BUS" refresh
	start_repair_watcher
}

start_service() {
	local enabled stack

	config_load gl_modem_community
	config_get_bool enabled global enabled 1
	[ "$enabled" -eq 1 ] || return 0

	mkdir -p "$RUNTIME_DIR"
	if ! stack=$("$RUNTIME_STACK"); then
		"$LOGGER_BIN" -t gl-modem-community \
			"unsupported GL.iNet cellular stack; leaving stock runtime unchanged"
		rm -f "$STACK_FILE"
		return 1
	fi
	printf '%s\n' "$stack" >"$STACK_FILE"

	case "$stack" in
	modern)
		start_modern
		;;
	legacy)
		start_legacy
		;;
	*)
		rm -f "$STACK_FILE"
		return 1
		;;
	esac
}

stop_service() {
	stack=$(cat "$STACK_FILE" 2>/dev/null || true)

	"$NETWORK_REPAIR" --restore || true
	case "$stack" in
	modern)
		is_model_list_mounted && "$UMOUNT_BIN" "$STOCK_LIST"
		is_modem_at_mounted && "$UMOUNT_BIN" "$MODEM_AT"
		;;
	legacy)
		"$LEGACY_BUS" restore
		;;
	esac
	rm -f "$STACK_FILE"
	return 0
}

reload_service() {
	stop_service
	start_service
	ubus call cellular.status cleanup_resources >/dev/null 2>&1 || true
}
