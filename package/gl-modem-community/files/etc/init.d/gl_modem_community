#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-3.0-only

START=22
STOP=78
USE_PROCD=1

RUNTIME_DIR=/var/run/gl-modem-community
STOCK_LIST=/lib/modem_data/modem_list.json
MERGED_LIST=$RUNTIME_DIR/modem_list.json
MODEM_AT=/usr/bin/modem_AT
STOCK_MODEM_AT=$RUNTIME_DIR/modem_AT.stock
MODEM_AT_WRAPPER=/usr/libexec/gl-modem-community/modem_AT-wrapper
USB_DEVICES_ROOT=${USB_DEVICES_ROOT:-/sys/bus/usb/devices}
UCI_BIN=${UCI_BIN:-uci}

set_network_option() {
	local section=$1 option=$2 value=$3 current
	current=$("$UCI_BIN" -q get "network.$section.$option" 2>/dev/null || true)
	[ "$current" = "$value" ] && return 1
	"$UCI_BIN" set "network.$section.$option=$value"
}

repair_fm350_network() {
	local path bus pid section ip_type changed=0 section_changed

	for path in "$USB_DEVICES_ROOT"/*; do
		[ -r "$path/idVendor" ] && [ "$(cat "$path/idVendor")" = 0e8d ] || continue
		pid=$(cat "$path/idProduct" 2>/dev/null || true)
		case "$pid" in 7126|7127) ;; *) continue ;; esac

		bus=${path##*/}
		section=modem_$(printf '%s' "$bus" | tr '.:-' '___')_s1
		"$UCI_BIN" -q get "network.$section" >/dev/null 2>&1 || continue

		section_changed=0
		set_network_option "$section" proto xmm && section_changed=1
		set_network_option "$section" bus "$bus" && section_changed=1
		set_network_option "$section" profile 5 && section_changed=1
		ip_type=$("$UCI_BIN" -q get "network.$section.ip_type" 2>/dev/null || true)
		case "$ip_type" in
			IP|IPV6|IPV4V6) set_network_option "$section" pdp "$ip_type" && section_changed=1 ;;
		esac
		[ "$section_changed" -eq 0 ] || {
			changed=1
			logger -t gl-modem-community "repaired stock FM350 interface $section bus=$bus proto=xmm profile=5"
		}
	done

	[ "$changed" -eq 0 ] || {
		"$UCI_BIN" commit network
	}
}

is_mounted() {
	grep -F " $STOCK_LIST " /proc/mounts >/dev/null 2>&1
}

is_modem_at_mounted() {
	grep -F " $MODEM_AT " /proc/mounts >/dev/null 2>&1
}

mount_modem_at_wrapper() {
	is_modem_at_mounted && return 0
	cp -p "$MODEM_AT" "$STOCK_MODEM_AT" || return 1
	mount -o bind "$MODEM_AT_WRAPPER" "$MODEM_AT" || return 1
}

start_service() {
	local enabled
	config_load gl_modem_community
	config_get_bool enabled global enabled 1
	[ "$enabled" -eq 1 ] || return 0

	mkdir -p "$RUNTIME_DIR"
	mount_modem_at_wrapper || return 1
	/usr/libexec/gl-modem-community/merge-models \
		"$STOCK_LIST" /usr/share/gl-modem-community/drivers.d "$MERGED_LIST" || return 1

	is_mounted || mount -o bind "$MERGED_LIST" "$STOCK_LIST" || return 1
	repair_fm350_network
}

stop_service() {
	is_mounted && umount "$STOCK_LIST"
	is_modem_at_mounted && umount "$MODEM_AT"
	return 0
}

reload_service() {
	stop_service
	start_service
	ubus call cellular.status cleanup_resources >/dev/null 2>&1 || true
}
